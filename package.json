{
  "name": "the-mindful-flow",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:mem": "concurrently \"pnpm --filter @mindful-flow/server dev:mem\" \"pnpm --filter @mindful-flow/client dev\"",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:api": "turbo run test --filter=@mindful-flow/server",
    "test:e2e": "turbo run test --filter=@mindful-flow/e2e",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@9.15.0"
}
